 } from \"./actionTypes\"\r\n\r\nconst initState = {\r\n    message: \"\",\r\n    loginMessage: '',\r\n    isError: '',\r\n    isLoading: false,\r\n    regAuth: false,\r\n    auth: false\r\n}\r\nconst register_reducer = (state = initState, { type, data, regAuth, auth }) => {\r\n    switch (type) {\r\n        case CREATE_ACCOUNT_REQUEST:\r\n            return {\r\n                ...state,\r\n                isError: false,\r\n                isLoading: true\r\n            }\r\n        case CREATE_ACCOUNT_SUCCESS:\r\n            return {\r\n                ...state,\r\n                message: data.message,\r\n                regAuth: true,\r\n                isError: false,\r\n                isLoading: false\r\n            }\r\n        case CREATE_ACCOUNT_FAILURE:\r\n            return {\r\n                ...state,\r\n                isError: data,\r\n                isLoading: false\r\n            }\r\n        \r\n// Login\r\n        case LOGIN_REQUEST:\r\n            return {\r\n                ...state,\r\n                isError: false,\r\n                isLoading: true\r\n            }\r\n        case LOGIN_SUCCESS:\r\n            return {\r\n                ...state,\r\n                loginMessage: data.token,\r\n                auth: true,\r\n                isError: false,\r\n                isLoading: false\r\n            }\r\n        case LOGIN_FAILURE:\r\n            return {\r\n                ...state,\r\n                isError: data,\r\n                isLoading: false\r\n            }\r\n    \r\n        default: return state\r\n    }\r\n} \r\nexport {register_reducer}","C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\app\\action.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\app\\actionTypes.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\