21"},{"filePath":"173","messages":"174","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"175","messages":"176","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\index.js",[],["177","178"],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\reportWebVitals.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\App.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Components\\Registration.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\store.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Routes\\Route.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Routes\\Navbar.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Components\\Login.jsx",["179","180","181","182"],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Components\\Home.jsx",["183","184"],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\auth\\action.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\auth\\actionTypes.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\auth\\reducer.js",["185"],"import { CREATE_ACCOUNT_FAILURE, CREATE_ACCOUNT_REQUEST, CREATE_ACCOUNT_SUCCESS, LOGIN_AUTH, LOGIN_FAILURE, LOGIN_REQUEST, LOGIN_SUCCESS } from \"./actionTypes\"\r\n\r\nconst initState = {\r\n    message: \"\",\r\n    loginMessage: '',\r\n    isError: '',\r\n    isLoading: false,\r\n    regAuth: false,\r\n    auth: false\r\n}\r\nconst register_reducer = (state = initState, { type, data, regAuth, auth }) => {\r\n    switch (type) {\r\n        case CREATE_ACCOUNT_REQUEST:\r\n            return {\r\n                ...state,\r\n                isError: false,\r\n                isLoading: true\r\n            }\r\n        case CREATE_ACCOUNT_SUCCESS:\r\n            return {\r\n                ...state,\r\n                message: data.message,\r\n                regAuth: true,\r\n                isError: false,\r\n                isLoading: false\r\n            }\r\n        case CREATE_ACCOUNT_FAILURE:\r\n            return {\r\n                ...state,\r\n                isError: data,\r\n                isLoading: false\r\n            }\r\n        \r\n// Login\r\n        case LOGIN_REQUEST:\r\n            return {\r\n                ...state,\r\n                isError: false,\r\n                isLoading: true\r\n            }\r\n        case LOGIN_SUCCESS:\r\n            return {\r\n                ...state,\r\n                loginMessage: data.token,\r\n                auth: true,\r\n                isError: false,\r\n                isLoading: false\r\n            }\r\n        case LOGIN_FAILURE:\r\n            return {\r\n                ...state,\r\n                isError: data,\r\n                isLoading: false\r\n            }\r\n    \r\n        default: return state\r\n    }\r\n} \r\nexport {register_reducer}","C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\app\\action.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\app\\actionTypes.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-thunk\\src\\Redux\\register\\app\\reducer.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\index.js",[],["186","187"],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\App.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\reportWebVitals.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Routes\\Route.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Routes\\Navbar.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Home.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Registration.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Login.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\app\\action.js",["188"],"import * as toodActions from \"./actionTypes\";\r\nimport axios from 'axios';\r\n\r\nconst getTodoRequest = () => {\r\n    return {\r\n        type: toodActions.GET_TODO_REQUEST,\r\n    };\r\n};\r\nconst getTodoSuccess = (data) => {\r\n    return {\r\n        type: toodActions.GET_TODO_SUCCESS,\r\n        data: data\r\n    }\r\n};\r\nconst getTodoFailure = (id) => {\r\n    return {\r\n        type: toodActions.GET_TODO_FAILURE,\r\n    }\r\n};\r\nconst changeTheme = (link) => {\r\n    return {\r\n        type: toodActions.CHANGE_THEME,\r\n        link\r\n    }\r\n}\r\n\r\nexport { getTodoRequest, getTodoSuccess, getTodoFailure, changeTheme };\r\n    \r\nexport const getTodo = (params = {}) => async dispatch => {\r\n    dispatch(getTodoRequest())\r\n    try {\r\n        const res = await axios.get('https://him-app.herokuapp.com/posts');\r\n        dispatch(getTodoSuccess(res.data));\r\n    } catch (err) {\r\n        return dispatch(getTodoFailure(err));\r\n    }\r\n}\r\n\r\n\r\nconst postTodoRequest = () => {\r\n    return {\r\n        type: toodActions.POST_TODO_REQUEST,\r\n    };\r\n};\r\nconst postTodoSuccess = (data) => {\r\n    return {\r\n        type: toodActions.POST_TODO_SUCCESS,\r\n        data: data\r\n    }\r\n};\r\nconst postTodoFailure = (id) => {\r\n    return {\r\n        type: toodActions.POST_TODO_FAILURE,\r\n    }\r\n};\r\nexport { postTodoRequest, postTodoSuccess, postTodoFailure };\r\n    \r\nexport const postTodo = (title) => async dispatch => {\r\n    dispatch(postTodoRequest())\r\n    try {\r\n        const res = await axios.post('https://him-app.herokuapp.com/posts', {\r\n            ...title,\r\n            status: false\r\n        });\r\n        dispatch(getTodo());\r\n        return {\r\n            success: true\r\n        };\r\n    } catch (err) {\r\n        return dispatch(postTodoFailure(err));\r\n    }\r\n}\r\n\r\nexport const updateTodo = (status, id) => dispatch => {\r\n    axios.patch(`https://him-app.herokuapp.com/posts/${id}`, {\r\n        status\r\n    })\r\n    .then((res)=> dispatch(getTodo()))\r\n}\r\nexport const editTodo = (n, val, id) => dispatch => {\r\n    \r\n    axios.patch(`https://him-app.herokuapp.com/posts/${id}`, {[n]: val})\r\n    .then((res)=> dispatch(getTodo()))\r\n}\r\nexport const deleteTodo = (id) => dispatch => {\r\n    axios.delete(`https://him-app.herokuapp.com/posts/${id}`)\r\n    .then((res)=> dispatch(getTodo()))\r\n}","C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\app\\actionTypes.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\auth\\action.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Todo.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\TodoList.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\auth\\actionTypes.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\store.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\app\\reducer.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Redux\\auth\\reducer.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Utils.js",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Routes\\Sidebar.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\CreateTask.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Card.jsx",["189","190"],"/* eslint-disable no-undef */\r\n/* eslint-disable no-restricted-globals */\r\nimport { Button, Dialog } from '@material-ui/core'\r\nimport React from 'react'\r\nimport \"./Styling/Card.css\"\r\nimport DialogActions from '@material-ui/core/DialogActions';\r\nimport DialogContent from '@material-ui/core/DialogContent';\r\nimport DialogContentText from '@material-ui/core/DialogContentText';\r\nimport DialogTitle from '@material-ui/core/DialogTitle';\r\nimport Slide from '@material-ui/core/Slide';\r\nimport { useHistory } from 'react-router';\r\n\r\n\r\nconst Transition = React.forwardRef(function Transition(props, ref) {\r\n    return <Slide direction=\"up\" ref={ref} {...props} />\r\n  });\r\n\r\nexport const Card = (props) => {\r\n    const [open, setOpen] = React.useState(false);\r\n\r\n    const clickOPenHAndler = () => {\r\n        setOpen(true);\r\n    };\r\n\r\n    const handleClose = () => {\r\n        setOpen(false);\r\n    };\r\n    const history = useHistory();\r\n    const handleTaskPage = () => {\r\n        history.push(`task/${props.id}`)\r\n    }\r\n    return (\r\n        <div className=\"cards\" key={props.id}>\r\n            <div className=\"top\">\r\n                <div>{props.date}</div>\r\n                <button className='statusBtn'\r\n                    onClick={()=>props.statusHandler(props.id)}\r\n                    style={{ color: `${props.status ? 'green' : 'orange'}`, cursor:'pointer' }}\r\n                >\r\n                    <i class=\"fas fa-check-circle\"></i>\r\n                </button>\r\n                <button className=\"deleteBtn\"\r\n                    \r\n                    onClick={()=>clickOPenHAndler()}\r\n                >\r\n                    <i class=\"fas fa-trash-alt\"></i>\r\n                </button>\r\n            </div>\r\n            <div onClick={()=>handleTaskPage(props.id)}>\r\n                <div className=\"title\">{`${props.title}`}</div>\r\n                <div style={{display:'flex', justifyContent:'space-between', fontWeight: '500'}}>\r\n                    <div>{props.personal && \"Personal\" }</div>\r\n                    <div>{ props.official && \"Official\"}</div>\r\n                    <div>{ props.other && \"Other\"}</div>\r\n                </div>\r\n                <p className=\"description\">{ props.des}</p>\r\n                <div>\r\n                    {props.subtask?.map((item, index) => (\r\n                        <div className='subtask' key={index}>\r\n                            <button><i class=\"far fa-check-square\"></i></button>\r\n                            <div>{item}</div>\r\n                        </div>\r\n                    ))}\r\n                </div>\r\n            </div>\r\n            <Dialog\r\n                open={open}\r\n                TransitionComponent={Transition}\r\n                keepMounted\r\n                onClose={handleClose}\r\n                aria-labelledby=\"alert-dialog-slide-title\"\r\n                aria-describedby=\"alert-dialog-slide-description\"\r\n            >\r\n                <DialogTitle id=\"alert-dialog-slide-title\">{\"Do you really want to delete your task?\"}</DialogTitle>\r\n                <DialogActions>\r\n                <Button onClick={handleClose} color=\"primary\">\r\n                    NO\r\n                </Button>\r\n                <Button onClick={() => props.deleteHandler(props.id)} color=\"primary\">\r\n                    YES\r\n                </Button>\r\n                </DialogActions>\r\n            </Dialog>\r\n        </div>\r\n    )\r\n}\r\n","C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Personal.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Official.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Other.jsx",[],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\ThemeMenu.jsx",["191"],"import React, { useState } from 'react';\r\nimport Button from '@material-ui/core/Button';\r\nimport ClickAwayListener from '@material-ui/core/ClickAwayListener';\r\nimport Grow from '@material-ui/core/Grow';\r\nimport Paper from '@material-ui/core/Paper';\r\nimport Popper from '@material-ui/core/Popper';\r\nimport MenuItem from '@material-ui/core/MenuItem';\r\nimport MenuList from '@material-ui/core/MenuList';\r\nimport { makeStyles } from '@material-ui/core/styles';\r\nimport { useDispatch, useSelector } from 'react-redux';\r\nimport { changeTheme } from '../Redux/app/action';\r\n// import {changeTheme} from '../Redux/app/action'\r\n\r\nconst useStyles = makeStyles((theme) => ({\r\n  root: {\r\n    display: 'flex',\r\n  },\r\n  paper: {\r\n    marginRight: theme.spacing(2),\r\n  },\r\n}));\r\n\r\nexport default function MenuListComposition() {\r\n    const dispatch = useDispatch();\r\n    const theme = useSelector(state => state.app.theme)\r\n  const classes = useStyles();\r\n  const [open, setOpen] = React.useState(false);\r\n  const anchorRef = React.useRef(null);\r\n\r\n  const handleToggle = () => {\r\n    setOpen((prevOpen) => !prevOpen);\r\n  };\r\n\r\n    const handleClose = (event, num) => {\r\n        const temp = [...theme];\r\n        const updated = temp.find((item, index) => index === num)\r\n        console.log(updated, num)\r\n    dispatch(changeTheme(updated))\r\n    if (anchorRef.current && anchorRef.current.contains(event.target)) {\r\n      return;\r\n    }\r\n\r\n    setOpen(false);\r\n  };\r\n\r\n  function handleListKeyDown(event) {\r\n    if (event.key === 'Tab') {\r\n      event.preventDefault();\r\n      setOpen(false);\r\n    }\r\n  }\r\n\r\n  // return focus to the button when we transitioned from !open -> open\r\n  const prevOpen = React.useRef(open);\r\n  React.useEffect(() => {\r\n    if (prevOpen.current === true && open === false) {\r\n      anchorRef.current.focus();\r\n    }\r\n\r\n    prevOpen.current = open;\r\n  }, [open]);\r\n\r\n  return (\r\n    <div className={classes.root}>\r\n      \r\n      <div>\r\n        <Button\r\n          ref={anchorRef}\r\n          aria-controls={open ? 'menu-list-grow' : undefined}\r\n          aria-haspopup=\"true\"\r\n          onClick={handleToggle} style={{color:'black'}}\r\n        >\r\n          THEME\r\n        </Button>\r\n        <Popper open={open} anchorEl={anchorRef.current} role={undefined} transition disablePortal>\r\n          {({ TransitionProps, placement }) => (\r\n            <Grow\r\n              {...TransitionProps}\r\n              style={{ transformOrigin: placement === 'bottom' ? 'center top' : 'center bottom' }}\r\n            >\r\n              <Paper>\r\n                <ClickAwayListener onClickAway={handleClose}>\r\n                  <MenuList autoFocusItem={open} id=\"menu-list-grow\" onKeyDown={handleListKeyDown}>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 0)}>Rose</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 1)}>office Evvironment</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 2)}>Slate</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 3)}>Marsala</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 4)}>Aloy</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 5)}>Nebula</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 6)}>Modern Flat</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 7)}>Branches</MenuItem>\r\n                    <MenuItem onClick={(e)=>handleClose(e, 8)}>Paradise</MenuItem>\r\n                  </MenuList>\r\n                </ClickAwayListener>\r\n              </Paper>\r\n            </Grow>\r\n          )}\r\n        </Popper>\r\n      </div>\r\n    </div>\r\n  );\r\n}","C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\Task.jsx",["192","193","194","195"],"C:\\Users\\HP\\Daily Asignments\\ti_050-himanshur\\unit-3\\sprint-4\\day-4\\you\\redux-advance-todo\\src\\Components\\EditModal.jsx",[],{"ruleId":"196","replacedBy":"197"},{"ruleId":"198","replacedBy":"199"},{"ruleId":"200","severity":1,"message":"201","line":1,"column":17,"nodeType":"202","messageId":"203","endLine":1,"endColumn":26},{"ruleId":"200","severity":1,"message":"204","line":10,"column":12,"nodeType":"202","messageId":"203","endLine":10,"endColumn":17},{"ruleId":"200","severity":1,"message":"205","line":10,"column":19,"nodeType":"202","messageId":"203","endLine":10,"endColumn":27},{"ruleId":"206","severity":1,"message":"207","line":15,"co